DATABASE_URL="postgresql://user:pass@localhost:5432/aichat"
REDIS_URL="redis://localhost:6379"

JWT_SECRET="change-me-256-bit-secret"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_SECRET="change-me-refresh-secret"
JWT_REFRESH_EXPIRES_IN="30d"

LIARA_AI_BASE_URL="https://your-ai.liara.run/v1"
LIARA_API_KEY="la-xxxxxxxx"

PAYMENT_GATEWAYS="zarinpal"
ZARINPAL_MERCHANT_ID="xxxx-xxxx-xxxx-xxxx"
VANDAR_API_KEY="xxxx-xxxx-xxxx-xxxx"
ZIBAL_MERCHANT_ID="xxxx-xxxx-xxxx-xxxx"

# حالت تست زیبال — true یعنی به‌جای ZIBAL_MERCHANT_ID از merchant تستی «ZIBAL» استفاده می‌شود
ZIBAL_TEST="false"

# لاگین با شماره 09001111111 و کد 123654 بدون ارسال پیامک واقعی
TEST_USER="false"

# محدودیت‌های OTP (به ثانیه) — اختیاری، پیش‌فرض‌ها همین مقادیرند
OTP_TTL_SECONDS=120
OTP_RATE_LIMIT=3
OTP_RATE_WINDOW_SECONDS=600
OTP_ATTEMPT_LIMIT=5
OTP_ATTEMPT_WINDOW_SECONDS=1800

KAVENEGAR_API_KEY="xxxxxxxxxx"
KAVENEGAR_TEMPLATE="loginotp"

APP_URL="http://localhost:3000"
PORT=3001
